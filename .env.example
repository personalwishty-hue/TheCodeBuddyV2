# Copy this file to .env and fill in real values.
# Add .env to your .gitignore – never commit credentials.

DISCORD_TOKEN=your-discord-bot-token-here
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-anon-key-here

# Comma-separated list of Discord channel names to monitor
MONITORED_CHANNELS=general,blox-fruits-codes,announcements
